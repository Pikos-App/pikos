{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pikos",
  "version": "0.1.0",
  "identifier": "app.pikos.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pikos",
        "width": 1480,
        "height": 920,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBRTE4N0ZFOTFFMzgwMzkKUldRNWdPT1Ivb2ZobXNBUlFJSEFzZm5iUEoxV1lkVGxPQ1B0SUZybXhtYk1OVXBuUE50NjVYRWEK",
      "endpoints": [
        "https://github.com/alex-ak/pkos/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "category": "Productivity",
    "shortDescription": "Notes, tasks, and calendar — local-first",
    "longDescription": "Pikos combines notes, tasks, and a calendar into one local-first app. Your data stays on your device — no account required, no cloud sync by default."
  }
}
