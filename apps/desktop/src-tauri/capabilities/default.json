{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-save",
    "fs:default",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-read",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "/Users/alex/Documents/pikos" },
        { "path": "/Users/alex/Documents/pikos/**" },
        { "path": "$HOME/Documents/pikos" },
        { "path": "$HOME/Documents/pikos/**" }
      ]
    }
  ]
}
