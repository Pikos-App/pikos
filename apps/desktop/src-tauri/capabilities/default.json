{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-save",
    "dialog:default",
    "fs:default",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-read",
    "fs:allow-read-file",
    "core:window:allow-set-decorations",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "process:allow-restart",
    "updater:default",
    "notification:default",
    "log:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
