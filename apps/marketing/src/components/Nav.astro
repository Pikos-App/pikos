---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  /** Current page path — used to highlight active link */
  current?: string;
}
const { current = "/" } = Astro.props;

const links = [
  { href: "/blog", label: "Blog" },
  { href: "/release-notes", label: "Release Notes" },
];
---

<nav class="mx-auto flex max-w-6xl items-center justify-between px-8 py-5">
  <a
    href="/"
    class="flex items-center gap-2 text-base font-semibold text-neutral-900 transition-opacity hover:opacity-80 dark:text-neutral-50"
  >
    <svg viewBox="0 0 200 200" width="22" height="22" aria-hidden="true" class="shrink-0 text-brand-500 dark:text-brand-400">
      <rect x="90" y="36" width="80" height="108" rx="9" fill="none" stroke="currentColor" stroke-width="12" opacity="0.6" />
      <rect x="60" y="54" width="80" height="108" rx="9" fill="none" stroke="currentColor" stroke-width="12" opacity="0.9" />
      <rect x="30" y="72" width="80" height="108" rx="9" fill="currentColor" />
    </svg>
    Pikos
  </a>
  <div class="flex items-center gap-6">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={[
          "text-sm transition-colors",
          current === l.href
            ? "font-medium text-neutral-900 dark:text-neutral-50"
            : "text-neutral-400 hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-50",
        ]}
      >
        {l.label}
      </a>
    ))}
    <ThemeToggle />
    <a
      href="/download"
      class="rounded-lg bg-brand-500 dark:bg-brand-400 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-brand-600 dark:hover:bg-brand-500"
    >
      Download
    </a>
  </div>
</nav>
