---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Changelog - Pikos" description="What's new in Pikos. A running log of features, fixes, and improvements.">

  <main class="mx-auto max-w-2xl px-8 py-20">

    <!-- Back to home -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-400 transition-colors hover:text-orange-500 dark:text-gray-500 dark:hover:text-orange-400">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      Home
    </a>

    <h1 class="mt-8 text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-50">Changelog</h1>
    <p class="mt-3 text-sm text-gray-400 dark:text-gray-500">A running log of what ships in each release.</p>

    <div class="mt-12 space-y-16">

      <!-- ── 1.0 ─────────────────────────────────────────────────────── -->
      <article>
        <div class="flex items-baseline gap-3">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-50">1.0</h2>
          <span class="rounded-full bg-orange-100 px-2.5 py-0.5 text-xs font-medium text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Initial Release</span>
        </div>
        <time class="mt-1 block text-sm text-gray-400 dark:text-gray-500" datetime="2026-04-01">April 1, 2026</time>

        <div class="mt-6 space-y-6 text-base leading-relaxed text-gray-600 dark:text-gray-300">

          <p>
            The first public release of Pikos. Notes, tasks, and calendar — unified in a single local-first desktop app.
          </p>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Editor</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>Rich text editor with bold, italic, underline, strikethrough, and inline code</li>
            <li>Headings (H1, H2, H3), bullet lists, ordered lists, task checklists, code blocks, and blockquotes</li>
            <li>Slash command menu — type <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm dark:bg-gray-800">/</code> to insert any block type with fuzzy search</li>
            <li>Floating format toolbar on text selection</li>
            <li>Link insertion and auto-linking on paste</li>
            <li>Find in page with match highlighting and navigation</li>
            <li>Markdown paste support — paste Markdown and it converts to rich text</li>
            <li>Autosave with optimistic UI updates</li>
          </ul>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Pages &amp; Organization</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>Quick add dialog with natural language parsing — extracts priority, due date, tags, and folder automatically</li>
            <li>Page status tracking: Not Started, In Progress, Done</li>
            <li>Four-level priority system: Urgent, High, Medium, Low</li>
            <li>Tag system with inline creation, search, and autocomplete</li>
            <li>Folders with custom colors for visual organization</li>
            <li>Smart views: Today (scheduled + overdue) and Inbox (unfoldered pages)</li>
            <li>Sort by manual order, date, title, or priority — persisted per view</li>
            <li>Drag-and-drop reordering within views and across folders</li>
            <li>Soft delete with undo</li>
          </ul>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Calendar</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>Week calendar view with all-day and timed events</li>
            <li>Drag to reschedule pages on the calendar</li>
            <li>Click a time slot to create a new page</li>
            <li>Live "now" indicator</li>
            <li>Arrow keys for week navigation, <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm dark:bg-gray-800">T</code> to jump to today</li>
            <li>Date and time picker with duration preservation</li>
          </ul>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Search</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>Full-text search palette with BM25 ranking — title matches rank first</li>
            <li>Content preview with query highlighting</li>
            <li>Results show priority, date, and tags inline</li>
          </ul>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Layout &amp; Navigation</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>Three-panel layout: sidebar, page list, editor or calendar</li>
            <li>Resizable panels with persistent widths</li>
            <li>Collapsible sidebar</li>
            <li>Toggle between editor and calendar view</li>
            <li>Full keyboard navigation — arrow keys, shortcuts for every action</li>
            <li>Context menus for pages and folders</li>
          </ul>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Data &amp; Privacy</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>All data stored locally in SQLite — nothing leaves your device</li>
            <li>No account required, no sign-up</li>
            <li>Export as SQLite backup or human-readable JSON</li>
            <li>Open, portable database format</li>
          </ul>

          <h3 class="pt-2 text-lg font-semibold text-gray-900 dark:text-gray-50">Appearance</h3>
          <ul class="list-disc space-y-1.5 pl-5">
            <li>Light, dark, and system theme modes</li>
            <li>Keyboard shortcuts reference in settings</li>
          </ul>

        </div>
      </article>

    </div>

    <Footer current="/changelog" />

  </main>
</Base>

<style>
  :global(body) {
    background-color: #fafaf9;
  }

  :global(html.dark body) {
    background-color: #030712;
  }
</style>
