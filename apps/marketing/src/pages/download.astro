---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Download Pikos" description="Download Pikos for Mac or Linux. Free, no sign-up, no tracking.">

  <main class="mx-auto max-w-2xl px-8 py-20">

    <!-- Back to home -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-400 transition-colors hover:text-orange-500 dark:text-gray-500 dark:hover:text-orange-400">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      Home
    </a>

    <h1 class="mt-8 text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-50">Download</h1>
    <p class="mt-3 text-base text-gray-500 dark:text-gray-400">
      Free to use. No account, no subscription, no catch.
    </p>

    <!-- Platform cards -->
    <div class="mt-12 grid gap-4 sm:grid-cols-2">

      <!-- macOS -->
      <a
        href="/download/mac"
        data-umami-event="download-mac"
        class="group flex flex-col items-center rounded-xl border border-gray-200 bg-white px-6 py-8 text-center transition-colors hover:border-orange-300 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 transition-colors group-hover:text-orange-500 dark:text-gray-500" aria-hidden="true">
          <rect width="20" height="14" x="2" y="3" rx="2"/>
          <path d="M8 21h8"/><path d="M12 17v4"/>
        </svg>
        <span class="mt-4 text-lg font-semibold text-gray-900 dark:text-gray-50">macOS</span>
        <span class="mt-1 text-sm text-gray-400 dark:text-gray-500">Intel &amp; Apple Silicon</span>
        <span class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-orange-500 px-5 py-2 text-sm font-medium text-white transition-colors group-hover:bg-orange-400">
          Download .dmg
        </span>
        <span class="mt-3 text-xs text-gray-400 dark:text-gray-500">Requires macOS 11+</span>
      </a>

      <!-- Linux -->
      <a
        href="/download/linux"
        data-umami-event="download-linux"
        class="group flex flex-col items-center rounded-xl border border-gray-200 bg-white px-6 py-8 text-center transition-colors hover:border-orange-300 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 transition-colors group-hover:text-orange-500 dark:text-gray-500" aria-hidden="true">
          <rect width="18" height="18" x="3" y="3" rx="2"/>
          <path d="m10 8 4 4-4 4"/>
        </svg>
        <span class="mt-4 text-lg font-semibold text-gray-900 dark:text-gray-50">Linux</span>
        <span class="mt-1 text-sm text-gray-400 dark:text-gray-500">x86_64</span>
        <span class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-orange-500 px-5 py-2 text-sm font-medium text-white transition-colors group-hover:bg-orange-400">
          Download .AppImage
        </span>
        <span class="mt-3 text-xs text-gray-400 dark:text-gray-500">Also available as .deb</span>
      </a>

    </div>

    <!-- Info -->
    <div class="mt-12 space-y-6 text-sm text-gray-500 dark:text-gray-400">

      <div>
        <h2 class="font-medium text-gray-700 dark:text-gray-300">What you get</h2>
        <p class="mt-1">
          The full app — notes, tasks, and calendar. Everything stored locally on your device. Nothing is locked behind a paywall or upgrade.
        </p>
      </div>

      <div>
        <h2 class="font-medium text-gray-700 dark:text-gray-300">iCloud sync</h2>
        <p class="mt-1">
          Coming soon via the Mac App Store. Buy once, sync across your Mac and iPhone through your own iCloud account. No subscription.
        </p>
      </div>

      <div>
        <h2 class="font-medium text-gray-700 dark:text-gray-300">All releases</h2>
        <p class="mt-1">
          Previous versions and changelogs are available on <a href="https://github.com/pikos-app/pikos/releases" class="text-orange-500 hover:underline">GitHub Releases</a>.
          See what's new on the <a href="/release-notes" class="text-orange-500 hover:underline">release notes</a> page.
        </p>
      </div>

    </div>

    <Footer current="/download" />

  </main>
</Base>

<style>
  :global(body) {
    background-color: #fafaf9;
  }

  :global(html.dark body) {
    background-color: #030712;
  }
</style>
