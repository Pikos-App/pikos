---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Download Pikos" description="Download Pikos for Mac or Linux. Free, no sign-up, no tracking.">

  <main class="mx-auto max-w-2xl px-8 py-20">

    <!-- Back to home -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-neutral-400 transition-colors hover:text-primary-500 dark:text-neutral-500 dark:hover:text-primary-400">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      Home
    </a>

    <h1 class="mt-8 text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">Download</h1>
    <p class="mt-3 text-base text-neutral-500 dark:text-neutral-400">
      Free to use. No account, no subscription, no catch.
    </p>

    <!-- Platform cards -->
    <div class="mt-12 grid gap-4 sm:grid-cols-2">

      <!-- macOS -->
      <div
        class="flex flex-col items-center rounded-xl border border-neutral-200 bg-white px-6 py-8 text-center dark:border-neutral-800 dark:bg-neutral-900"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 dark:text-neutral-500" aria-hidden="true">
          <rect width="20" height="14" x="2" y="3" rx="2"/>
          <path d="M8 21h8"/><path d="M12 17v4"/>
        </svg>
        <span class="mt-4 text-lg font-semibold text-neutral-900 dark:text-neutral-50">macOS</span>
        <span class="mt-1 text-sm text-neutral-400 dark:text-neutral-500">Intel &amp; Apple Silicon</span>
        <a
          href="https://github.com/pikos-app/pikos/releases/latest/download/Pikos-macos-universal.dmg"
          data-umami-event="download-mac"
          class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-brand-500 dark:bg-brand-400 px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-brand-600 dark:hover:bg-brand-500"
        >
          Download .dmg
        </a>
        <span class="mt-3 text-xs text-neutral-400 dark:text-neutral-500">Requires macOS 11+</span>
      </div>

      <!-- Linux -->
      <div
        class="flex flex-col items-center rounded-xl border border-neutral-200 bg-white px-6 py-8 text-center dark:border-neutral-800 dark:bg-neutral-900"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 dark:text-neutral-500" aria-hidden="true">
          <rect width="18" height="18" x="3" y="3" rx="2"/>
          <path d="m10 8 4 4-4 4"/>
        </svg>
        <span class="mt-4 text-lg font-semibold text-neutral-900 dark:text-neutral-50">Linux</span>
        <span class="mt-1 text-sm text-neutral-400 dark:text-neutral-500">x86_64</span>
        <a
          href="https://github.com/pikos-app/pikos/releases/latest/download/Pikos-linux-x86_64.AppImage"
          data-umami-event="download-linux-appimage"
          class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-brand-500 dark:bg-brand-400 px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-brand-600 dark:hover:bg-brand-500"
        >
          Download .AppImage
        </a>
        <a
          href="https://github.com/pikos-app/pikos/releases/latest/download/Pikos-linux-x86_64.deb"
          data-umami-event="download-linux-deb"
          class="mt-3 text-xs text-neutral-400 transition-colors hover:text-primary-500 dark:text-neutral-500 dark:hover:text-primary-400"
        >
          Prefer .deb? →
        </a>
      </div>

    </div>

    <!-- Back the project -->
    <div class="mt-12 rounded-xl border border-neutral-200 bg-white px-6 py-6 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="text-base font-semibold text-neutral-900 dark:text-neutral-50">Want to support development?</h2>
      <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
        Back Pikos for $29. When the iPhone app and Mac App Store version are ready, you'll get both free. No further payment, ever.
      </p>
      <a
        href="/backer"
        data-umami-event="download-back"
        class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-brand-500 dark:bg-brand-400 px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-brand-600 dark:hover:bg-brand-500"
      >
        Back Pikos · $29
      </a>
    </div>

    <!-- Info -->
    <div class="mt-12 space-y-6 text-sm text-neutral-500 dark:text-neutral-400">

      <div>
        <h2 class="font-medium text-neutral-700 dark:text-neutral-300">What you get</h2>
        <p class="mt-1">
          The full app: notes, tasks, and calendar. Everything stored locally on your device. Nothing locked behind a paywall or upgrade.
        </p>
      </div>

      <div>
        <h2 class="font-medium text-neutral-700 dark:text-neutral-300">iCloud sync</h2>
        <p class="mt-1">
          Coming via the Mac App Store. Buy once, sync across your Mac and iPhone through your own iCloud account. No subscription. Want to support the project and get the paid apps free? <a href="/backer" class="text-primary-500 hover:underline">Back Pikos</a>.
        </p>
      </div>

      <div>
        <h2 class="font-medium text-neutral-700 dark:text-neutral-300">All releases</h2>
        <p class="mt-1">
          Previous versions and changelogs are available on <a href="https://github.com/pikos-app/pikos/releases" class="text-primary-500 hover:underline">GitHub Releases</a>.
          See what's new on the <a href="/release-notes" class="text-primary-500 hover:underline">release notes</a> page.
        </p>
      </div>

    </div>

  </main>

  <Footer current="/download" />
</Base>

