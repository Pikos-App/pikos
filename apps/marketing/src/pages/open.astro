---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";

const githubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`;
---

<Base title="Pikos — Source-available notes, tasks, and calendar" description="Local-first productivity app built with Tauri 2, React, and SQLite. No server, no telemetry. Read the code, audit the claims, build from source." hideNav>

  <!-- Custom nav — GitHub replaces Download as primary CTA -->
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-8 py-5">
    <a href="/open" class="text-base font-semibold text-gray-900 transition-colors hover:text-orange-500 dark:text-gray-50 dark:hover:text-orange-400">
      Pikos
    </a>
    <div class="flex items-center gap-6">
      <a href="/" class="text-sm text-gray-400 transition-colors hover:text-gray-900 dark:text-gray-500 dark:hover:text-gray-50">Home</a>
      <a href="/blog" class="text-sm text-gray-400 transition-colors hover:text-gray-900 dark:text-gray-500 dark:hover:text-gray-50">Blog</a>
      <a href="/download" class="text-sm text-gray-400 transition-colors hover:text-gray-900 dark:text-gray-500 dark:hover:text-gray-50">Download</a>
      <a
        href="https://github.com/pikos-app/pikos"
        class="inline-flex items-center gap-2 rounded-lg bg-gray-900 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-gray-700 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-300"
      >
        <Fragment set:html={githubIcon.replace('width="18" height="18"', 'width="16" height="16"')} />
        GitHub
      </a>
    </div>
  </nav>

  <main class="mx-auto max-w-6xl px-8 py-20">

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:gap-16">

      <div class="max-w-xl shrink-0">
        <div class="flex items-center justify-between">
          <p class="text-base text-gray-500 dark:text-gray-400">Three apps is two too many.</p>
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="ml-4 shrink-0 cursor-pointer rounded-lg p-2 text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600 dark:text-gray-500 dark:hover:bg-gray-800 dark:hover:text-gray-300"
          >
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
            </svg>
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
            </svg>
          </button>
        </div>

        <h1 class="mt-4 text-6xl font-bold tracking-tight text-gray-900 leading-tight dark:text-gray-50">
          Notes, tasks,<br />and calendar.<br />
          <span class="text-orange-500">One database.</span>
        </h1>

        <p class="mt-6 text-xl leading-relaxed text-gray-500 dark:text-gray-400">
          Tauri 2 + React + SQLite. No server, no telemetry. The codebase is public so you can verify every claim.
        </p>

        <ul class="mt-5 space-y-2 text-sm text-gray-500 dark:text-gray-400">
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-orange-400">→</span>
            Source-available. Read the code, audit the privacy claims, build from source.
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-orange-400">→</span>
            Single SQLite file. Open format. Query your own data with any client.
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-orange-400">→</span>
            Zero network requests during normal use. No accounts, no phone-home.
          </li>
        </ul>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="https://github.com/pikos-app/pikos"
            data-umami-event="open-github"
            class="inline-flex items-center gap-2 rounded-lg bg-gray-900 px-7 py-3.5 text-base font-medium text-white transition-colors hover:bg-gray-700 focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:outline-none dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-300 dark:focus:ring-offset-gray-950"
          >
            <Fragment set:html={githubIcon} />
            View on GitHub
          </a>
          <a
            href="/download"
            class="inline-flex items-center rounded-lg border border-gray-300 px-7 py-3.5 text-base font-medium text-gray-700 transition-colors hover:border-gray-400 hover:text-gray-900 dark:border-gray-700 dark:text-gray-300 dark:hover:border-gray-500 dark:hover:text-gray-100"
          >
            Download — Free
          </a>
        </div>
      </div>

      <!-- Video -->
      <div class="w-full min-w-0">
        <div class="relative w-full rounded-xl ring-1 ring-black/8 dark:ring-white/10">
          <video src="/pikos-hero-light.mp4" autoplay loop muted playsinline class="w-full rounded-xl shadow-xl transition-opacity duration-200 dark:opacity-0"></video>
          <video src="/pikos-hero-dark.mp4" autoplay loop muted playsinline aria-hidden="true" class="absolute inset-0 w-full rounded-xl shadow-xl opacity-0 transition-opacity duration-200 dark:opacity-100"></video>
        </div>
      </div>

    </div>

    <!-- ─── Concept diagram ──────────────────────────────────────────────── -->
    <section class="mt-28 max-w-4xl">
      <p class="text-2xl font-semibold text-gray-800 dark:text-gray-100">Every page is a note, a task, and a calendar event.</p>
      <p class="mt-2 text-base leading-relaxed text-gray-500 dark:text-gray-400">
        Not three models bolted together. One <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm dark:bg-gray-800">pages</code> table that does all three.
      </p>

      <!-- Desktop (md+) -->
      <div class="relative mt-12 hidden h-80 md:block">
        <svg class="pointer-events-none absolute inset-0 h-full w-full" viewBox="0 0 896 320" preserveAspectRatio="none" aria-hidden="true">
          <line x1="208" y1="72"  x2="392" y2="160" stroke="#fdba74" stroke-width="1.5" stroke-dasharray="5,5"/>
          <line x1="208" y1="248" x2="392" y2="160" stroke="#fdba74" stroke-width="1.5" stroke-dasharray="5,5"/>
          <line x1="504" y1="160" x2="688" y2="160" stroke="#fdba74" stroke-width="1.5" stroke-dasharray="5,5"/>
          <circle cx="208" cy="72"  r="3.5" fill="#fdba74"/><circle cx="208" cy="248" r="3.5" fill="#fdba74"/><circle cx="688" cy="160" r="3.5" fill="#fdba74"/>
        </svg>
        <div class="absolute left-0 top-0 h-36 w-52 rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Write</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Rich text, headings, checklists, linked pages. A real writing surface.</p>
        </div>
        <div class="absolute bottom-0 left-0 h-36 w-52 rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400" aria-hidden="true"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Track</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Status, priority, due dates. Smart views filter what matters now.</p>
        </div>
        <div class="absolute left-1/2 top-1/2 flex h-28 w-28 -translate-x-1/2 -translate-y-1/2 flex-col items-center justify-center rounded-full border-2 border-orange-300 bg-orange-50 shadow-md dark:border-orange-700 dark:bg-orange-950">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          <span class="mt-1.5 text-sm font-bold text-gray-900 dark:text-gray-100">Page</span>
        </div>
        <div class="absolute right-0 top-1/2 h-36 w-52 -translate-y-1/2 rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Schedule</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Block time and see when you'll actually do it, not just when it's due.</p>
        </div>
      </div>

      <!-- Mobile (< md) -->
      <div class="mt-10 flex flex-col items-center md:hidden">
        <div class="w-full max-w-xs rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Write</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Rich text, headings, checklists, linked pages. A real writing surface.</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="h-6 w-px border-l border-dashed border-orange-300 dark:border-orange-700"></div>
          <div class="flex h-16 w-16 flex-col items-center justify-center rounded-full border-2 border-orange-300 bg-orange-50 shadow-sm dark:border-orange-700 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
            <span class="mt-0.5 text-xs font-bold text-gray-900 dark:text-gray-100">Page</span>
          </div>
          <div class="h-6 w-px border-l border-dashed border-orange-300 dark:border-orange-700"></div>
        </div>
        <div class="w-full max-w-xs rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400" aria-hidden="true"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Track</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Status, priority, due dates. Smart views filter what matters now.</p>
        </div>
        <div class="h-6 w-px border-l border-dashed border-orange-300 dark:border-orange-700"></div>
        <div class="w-full max-w-xs rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-400" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Schedule</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Block time and see when you'll actually do it, not just when it's due.</p>
        </div>
      </div>
    </section>

    <!-- ─── Features (matches / grid, technical descriptions) ──────────── -->
    <section class="mt-28 max-w-4xl">
      <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-100">What you can do with it</h2>

      <div class="mt-10 grid gap-8 sm:grid-cols-2">

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">Rich text editor</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">Tiptap on ProseMirror. Headings, checklists, code blocks, blockquotes. Slash commands, bubble toolbar, Markdown paste. Content stored as ProseMirror JSON in SQLite.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">Built-in calendar</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">Week view alongside the editor. Drag pages to time slots to schedule them. Click a slot to create a new page. Calendar and editor are one panel toggle apart.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">Full-text search</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">FTS5 with BM25 ranking. Title matches weighted higher. Content previews with query highlighting. Search palette opens with <code class="rounded bg-gray-100 px-1 py-0.5 text-xs dark:bg-gray-800">Cmd+K</code>.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">NL quick capture</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">Type naturally: "Call dentist tomorrow high priority #health" — parser extracts title, date, priority, and tags. No menus, no forms.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">Folders and smart views</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">Organize with folders and custom colors. Today view shows scheduled and overdue. Inbox catches unorganized pages. Sort by date, priority, or manual drag order.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">Private by default</h3>
          <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">All data in a local SQLite file. No accounts, no cloud, no tracking. Export as SQLite backup or JSON at any time. The code is public so you can verify every claim.</p>
        </div>

      </div>
    </section>

    <!-- ─── The stack (4-col cards) ──────────────────────────────────────── -->
    <section class="mt-28">
      <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-100">The stack</h2>
      <p class="mt-2 text-base text-gray-500 dark:text-gray-400">No Electron. No bundled Chromium. No cloud dependency.</p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-gray-900">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">Tauri 2</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">Rust backend, system webview. Small binary, instant startup, minimal memory.</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-gray-900">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-orange-50 dark:bg-orange-950">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500" aria-hidden="true"><path d="m7 8-4 4 4 4"/><path d="m17 8 4 4-4 4"/><path d="m14 4-4 16"/></svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">React + TypeScript</h3>
          <p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400">React 19 with the React Compiler. Strict TypeScript. Tiptap editor on ProseMirror.</p>
