---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Pikos - Notes, tasks, and calendar. Your device. Your data.">

  <main class="relative mx-auto max-w-6xl px-8 py-20">

    <!-- Hero -->
    <div class="relative flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:gap-16">

      <!-- Left: copy -->
      <div class="max-w-xl shrink-0">
        <p class="text-base text-neutral-500 dark:text-neutral-400">Most people juggle three apps to stay organized. You shouldn't have to.</p>

        <h1 class="mt-4 text-6xl font-bold tracking-tight leading-tight text-neutral-900 dark:text-neutral-50">
          Notes, tasks,<br /> and calendar.<br />
          <span class="text-brand-500 dark:text-brand-400">One app.</span>
        </h1>

        <p class="mt-6 text-xl leading-relaxed text-neutral-500 dark:text-neutral-400">
          Everything you need to think, plan, and do. Nothing leaves your device unless you want it to.
        </p>

        <ul class="mt-5 space-y-2 text-sm text-neutral-500 dark:text-neutral-400">
          <li class="flex items-center gap-2">
            <span class="mt-0.5 text-warning-400">→</span>
            Free to download. No subscription, no sign-up.
          </li>
          <li class="flex items-center gap-2">
            <span class="mt-0.5 text-warning-400">→</span>
            Your data stays on your device. I never see it.
          </li>
          <li class="flex items-center gap-2">
            <span class="mt-0.5 text-warning-400">→</span>
            Search everything instantly. Notes, tasks, and events, all at once.
          </li>
        </ul>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/download"
            data-umami-event="hero-download"
            class="inline-flex items-center justify-center rounded-lg bg-brand-500 dark:bg-brand-400 px-7 py-3.5 text-base font-medium text-white transition-colors hover:bg-brand-600 dark:hover:bg-brand-500 focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:outline-none dark:focus:ring-offset-neutral-950"
          >
            Download — Free
          </a>
          <span class="text-sm text-neutral-400 dark:text-neutral-500">macOS &amp; Linux</span>
        </div>
      </div>

      <!-- Right: product screenshot -->
      <div class="w-full min-w-0">
        <button
          id="hero-video-btn"
          aria-label="View full-size demo"
          class="group relative w-full rounded-xl ring-1 ring-black/8 dark:ring-white/10 pointer-events-none md:pointer-events-auto md:cursor-zoom-in md:focus:outline-none md:focus:ring-2 md:focus:ring-primary-400"
        >
          <video
            src="/pikos-hero-light.mp4"
            autoplay loop muted playsinline
            class="w-full rounded-xl shadow-xl transition-opacity duration-200 dark:opacity-0"
          ></video>
          <video
            src="/pikos-hero-dark.mp4"
            autoplay loop muted playsinline
            aria-hidden="true"
            class="absolute inset-0 w-full rounded-xl shadow-xl opacity-0 transition-opacity duration-200 dark:opacity-100"
          ></video>
          <div class="absolute inset-0 rounded-xl bg-black/0 transition-colors duration-200 md:group-hover:bg-black/5 md:dark:group-hover:bg-white/5"></div>
        </button>

        <!-- Lightbox -->
        <div
          id="lightbox"
          role="dialog"
          aria-modal="true"
          aria-label="Full-size demo"
          class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm"
        >
          <div class="relative w-[80vw] max-w-[80vw]">
            <button
              id="lightbox-close"
              aria-label="Close"
              class="absolute -right-3 -top-3 z-10 flex h-8 w-8 cursor-pointer items-center justify-center rounded-full bg-neutral-900 text-white shadow-lg ring-1 ring-white/20 transition-colors hover:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-white/60"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
            <video
              id="lightbox-video"
              autoplay loop muted playsinline
              class="w-full rounded-xl shadow-2xl"
              style="max-height: 80vh; object-fit: contain;"
            ></video>
          </div>
        </div>
      </div>

    </div>

    <!-- Concept section -->
    <section class="mt-28 max-w-4xl">
      <p class="text-2xl font-semibold text-neutral-800 dark:text-neutral-100">Every page is a note, a task, and a calendar event.</p>
      <p class="mt-2 text-base leading-relaxed text-neutral-500 dark:text-neutral-400">
        Not three things bolted together. One thing that does all three.
      </p>

      <!-- Desktop diagram (md+) -->
      <div class="relative mt-12 hidden h-80 md:block">
        <!--
          Section is max-w-4xl: content width = 896px (no extra padding here).
          Cards: w-52 (208px), h-36 (144px). Gap between left cards: 320-288=32px.
          Note:     left=0, top=0      → right edge x=208, center y=72
          Task:     left=0, bottom=0   → right edge x=208, center y=248 (320-72)
          Page:     center x=448 (50%), y=160 (50%), radius=56 → left=392, right=504
          Calendar: right=0, center y=160 → left edge x=688 (896-208)
          viewBox: 896 × 320 to match section dimensions exactly.
        -->
        <svg
          class="pointer-events-none absolute inset-0 h-full w-full text-neutral-400/60 dark:text-neutral-600/60"
          viewBox="0 0 896 320"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <line x1="208" y1="72"  x2="392" y2="160" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5,5"/>
          <line x1="208" y1="248" x2="392" y2="160" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5,5"/>
          <line x1="504" y1="160" x2="688" y2="160" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5,5"/>
          <circle cx="208" cy="72"  r="3.5" fill="currentColor"/>
          <circle cx="208" cy="248" r="3.5" fill="currentColor"/>
          <circle cx="688" cy="160" r="3.5" fill="currentColor"/>
        </svg>

        <!-- Note (top-left) -->
        <div class="absolute left-0 top-0 h-36 w-52 rounded-xl border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning-400" aria-hidden="true">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
            <path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Write</h3>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">Rich text, headings, checklists, linked pages. A real writing surface.</p>
        </div>

        <!-- Task (bottom-left) -->
        <div class="absolute bottom-0 left-0 h-36 w-52 rounded-xl border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning-400" aria-hidden="true">
            <path d="m9 11 3 3L22 4"/>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Track</h3>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">Status, priority, due dates. Recurring tasks just appear.</p>
        </div>

        <!-- Page (center) — terracotta identity anchor, not amber attention -->
        <div class="absolute left-1/2 top-1/2 flex h-28 w-28 -translate-x-1/2 -translate-y-1/2 flex-col items-center justify-center rounded-full bg-brand-500 shadow-md dark:bg-brand-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-white" aria-hidden="true">
            <rect width="7" height="9" x="3" y="3" rx="1"/>
            <rect width="7" height="5" x="14" y="3" rx="1"/>
            <rect width="7" height="9" x="14" y="12" rx="1"/>
            <rect width="7" height="5" x="3" y="16" rx="1"/>
          </svg>
          <span class="mt-1.5 text-sm font-bold text-white">Page</span>
        </div>

        <!-- Calendar (right) -->
        <div class="absolute right-0 top-1/2 h-36 w-52 -translate-y-1/2 rounded-xl border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning-400" aria-hidden="true">
            <path d="M8 2v4"/><path d="M16 2v4"/>
            <rect width="18" height="18" x="3" y="4" rx="2"/>
            <path d="M3 10h18"/>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Schedule</h3>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">Block time and see when you'll actually do it, not just when it's due.</p>
        </div>
      </div>

      <!-- Mobile vertical diagram (< md) -->
      <div class="mt-10 flex flex-col items-center md:hidden">

        <!-- Write -->
        <div class="w-full max-w-xs rounded-xl border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning-400" aria-hidden="true">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
            <path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Write</h3>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">Rich text, headings, checklists, linked pages. A real writing surface.</p>
        </div>

        <!-- Connector: neutral line → terracotta Page circle → neutral line -->
        <div class="flex flex-col items-center">
          <div class="h-6 w-px border-l border-dashed border-neutral-400/60 dark:border-neutral-600/60"></div>
          <div class="flex h-16 w-16 flex-col items-center justify-center rounded-full bg-brand-500 shadow-sm dark:bg-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-white" aria-hidden="true">
              <rect width="7" height="9" x="3" y="3" rx="1"/>
              <rect width="7" height="5" x="14" y="3" rx="1"/>
              <rect width="7" height="9" x="14" y="12" rx="1"/>
              <rect width="7" height="5" x="3" y="16" rx="1"/>
            </svg>
            <span class="mt-0.5 text-xs font-bold text-white">Page</span>
          </div>
          <div class="h-6 w-px border-l border-dashed border-neutral-400/60 dark:border-neutral-600/60"></div>
        </div>

        <!-- Task -->
        <div class="w-full max-w-xs rounded-xl border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning-400" aria-hidden="true">
            <path d="m9 11 3 3L22 4"/>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Track</h3>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">Status, priority, due dates. Recurring tasks just appear.</p>
        </div>

        <!-- Connector: plain line -->
        <div class="h-6 w-px border-l border-dashed border-neutral-400/60 dark:border-neutral-600/60"></div>

        <!-- Schedule -->
        <div class="w-full max-w-xs rounded-xl border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning-400" aria-hidden="true">
            <path d="M8 2v4"/><path d="M16 2v4"/>
            <rect width="18" height="18" x="3" y="4" rx="2"/>
            <path d="M3 10h18"/>
          </svg>
          <h3 class="mt-2 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Schedule</h3>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">Block time and see when you'll actually do it, not just when it's due.</p>
        </div>

      </div>
    </section>

    <!-- Features -->
    <section class="mt-28 max-w-4xl">
      <h2 class="text-2xl font-semibold text-neutral-800 dark:text-neutral-100">What you can do with it</h2>

      <div class="mt-10 grid gap-8 sm:grid-cols-2">

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 dark:text-neutral-400" aria-hidden="true">
              <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
              <path d="m15 5 4 4"/>
            </svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Rich text editor</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">Headings, bold, italic, checklists, code blocks, blockquotes. Slash commands to insert anything. Format toolbar on selection. Paste Markdown and it converts automatically.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 dark:text-neutral-400" aria-hidden="true">
              <path d="M8 2v4"/><path d="M16 2v4"/>
              <rect width="18" height="18" x="3" y="4" rx="2"/>
              <path d="M3 10h18"/>
            </svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Built-in calendar</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">Week view alongside your editor. Drag pages to time slots to schedule them. Click a slot to create a new page. Your notes and your schedule are always one glance apart.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 dark:text-neutral-400" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Instant full-text search</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">Search inside your pages, not just titles. Results ranked by relevance with content previews. Open the search palette and find anything in your workspace immediately.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 dark:text-neutral-400" aria-hidden="true">
              <path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/>
            </svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Quick capture</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">Type naturally: "Call dentist tomorrow high priority #health" creates a page with the title, date, priority, and tag already set. No menus, no forms.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 dark:text-neutral-400" aria-hidden="true">
              <rect width="7" height="7" x="14" y="3" rx="1"/>
              <path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/>
            </svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Folders and smart views</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">Organize with folders and custom colors. Today view shows what's scheduled and overdue. Inbox catches everything you haven't sorted yet. Sort by date, priority, or drag to reorder.</p>
        </div>

        <div>
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600 dark:text-neutral-400" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
            </svg>
          </div>
          <h3 class="mt-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Private by default</h3>
          <p class="mt-1 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">Everything stays on your device. No account, no cloud, no tracking. Export your data anytime in a format you can open anywhere.</p>
        </div>

      </div>
    </section>

    <!-- Pricing -->
    <section class="mt-28 max-w-4xl">
      <h2 class="text-2xl font-semibold text-neutral-800 dark:text-neutral-100">Free to download. No catch.</h2>
      <p class="mt-2 text-base leading-relaxed text-neutral-500 dark:text-neutral-400">
        The full app, every feature, no trial period. Pikos doesn't run servers, so there's no ongoing cost to pass on to you.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="/download" class="inline-flex items-center justify-center rounded-lg bg-brand-500 dark:bg-brand-400 px-7 py-3 text-base font-medium text-white transition-colors hover:bg-brand-600 dark:hover:bg-brand-500">
          Download
        </a>
        <span class="text-sm text-neutral-400 dark:text-neutral-500">macOS &amp; Linux</span>
      </div>

      <!-- Coming next -->
      <div class="mt-12 space-y-4 text-sm text-neutral-500 dark:text-neutral-400">
        <h3 class="font-medium text-neutral-700 dark:text-neutral-300">Coming next</h3>
        <ul class="space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-warning-400">→</span>
            iPhone app
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-warning-400">→</span>
            iCloud sync across your devices
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-warning-400">→</span>
            Mac App Store with one-time purchase
          </li>
        </ul>
        <p class="pt-2">
          Want to support development? <a href="/backer" class="text-primary-500 hover:underline">Back Pikos</a> and get the paid apps free when they ship.
        </p>
      </div>
    </section>

    <!-- Keyboard-driven callout -->
    <section class="mt-28 max-w-4xl">
      <div class="rounded-xl border border-neutral-200 bg-white px-8 py-8 dark:border-neutral-800 dark:bg-neutral-900">
        <p class="text-lg font-semibold text-neutral-800 dark:text-neutral-100">Keyboard-first</p>
        <p class="mt-2 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
          Every action has a shortcut. Navigate pages, switch views, create and schedule — without reaching for the mouse. If you live in your keyboard, Pikos stays out of your way.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <kbd class="rounded-md border border-primary-400/30 bg-neutral-50 px-2.5 py-1 text-xs font-medium text-neutral-600 dark:border-primary-400/40 dark:bg-neutral-800 dark:text-neutral-400">&#8984;N</kbd><span class="self-center text-xs text-neutral-400 dark:text-neutral-500">New page</span>
          <span class="mx-1.5 self-center text-neutral-200 dark:text-neutral-700">&middot;</span>
          <kbd class="rounded-md border border-primary-400/30 bg-neutral-50 px-2.5 py-1 text-xs font-medium text-neutral-600 dark:border-primary-400/40 dark:bg-neutral-800 dark:text-neutral-400">&#8984;K</kbd><span class="self-center text-xs text-neutral-400 dark:text-neutral-500">Search</span>
          <span class="mx-1.5 self-center text-neutral-200 dark:text-neutral-700">&middot;</span>
          <kbd class="rounded-md border border-primary-400/30 bg-neutral-50 px-2.5 py-1 text-xs font-medium text-neutral-600 dark:border-primary-400/40 dark:bg-neutral-800 dark:text-neutral-400">&#8984;&#8679;C</kbd><span class="self-center text-xs text-neutral-400 dark:text-neutral-500">Calendar</span>
          <span class="mx-1.5 self-center text-neutral-200 dark:text-neutral-700">&middot;</span>
          <kbd class="rounded-md border border-primary-400/30 bg-neutral-50 px-2.5 py-1 text-xs font-medium text-neutral-600 dark:border-primary-400/40 dark:bg-neutral-800 dark:text-neutral-400">/</kbd><span class="self-center text-xs text-neutral-400 dark:text-neutral-500">Slash commands</span>
        </div>
      </div>
    </section>

  </main>

  <Footer current="/" />
</Base>

<style>

  </style>

<script>
  // Lightbox
  const heroBtn = document.getElementById("hero-video-btn")!;
  const lightbox = document.getElementById("lightbox")!;
  const lightboxVideo = document.getElementById("lightbox-video") as HTMLVideoElement;
  const lightboxClose = document.getElementById("lightbox-close")!;

  function openLightbox() {
    if (window.innerWidth < 768) return;
    const dark = document.documentElement.classList.contains("dark");
    lightboxVideo.src = dark ? "/pikos-hero-dark.mp4" : "/pikos-hero-light.mp4";
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightboxVideo.pause();
    lightboxVideo.removeAttribute("src");
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  heroBtn.addEventListener("click", openLightbox);
  lightboxClose.addEventListener("click", closeLightbox);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });


</script>
