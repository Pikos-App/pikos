---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";

// Blog posts — add new entries here, newest first.
// Each post must have a matching file at /src/pages/blog/[slug].astro
const posts: { slug: string; title: string; description: string; date: string; tag: string }[] = [
  {
    slug: "the-code-is-public",
    title: "The Code Is Public",
    description: "The Pikos codebase is now source-available. What you can do with it, how it's licensed, and why it matters for trust.",
    date: "2026-06-10",
    tag: "Transparency",
  },
  {
    slug: "what-if-pikos-goes-away",
    title: "What If Pikos Goes Away?",
    description: "Your data is a file on your computer. The app works without a server. Here's what that means for longevity.",
    date: "2026-06-10",
    tag: "Philosophy",
  },
  {
    slug: "buy-once",
    title: "Buy Once",
    description: "No subscription, now or ever. The desktop app is free. The paid versions will be one-time purchases.",
    date: "2026-06-10",
    tag: "Pricing",
  },
  {
    slug: "your-data-stays-on-your-device",
    title: "Your Data Stays on Your Device",
    description: "Pikos doesn't have accounts, servers, or access to your data. Here's why.",
    date: "2026-05-09",
    tag: "Privacy",
  },
];

const tags = [...new Set(posts.map((p) => p.tag))];
---

<Base title="Blog - Pikos" description="Articles about Pikos: the app, the architecture, the philosophy.">

  <main class="mx-auto max-w-2xl px-8 py-20">

    <!-- Back to home -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-neutral-400 transition-colors hover:text-primary-500 dark:text-neutral-500 dark:hover:text-primary-400">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      Home
    </a>

    <h1 class="mt-8 text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">Blog</h1>
    <p class="mt-3 text-sm text-neutral-400 dark:text-neutral-500">Honest writing about building Pikos: the app, the decisions, the trade-offs.</p>

    <!-- Tag filters -->
    <div class="mt-6 flex flex-wrap gap-2">
      <button
        data-tag="all"
        class="tag-filter cursor-pointer rounded-full border border-neutral-200 px-3 py-1 text-xs font-medium text-neutral-600 transition-colors hover:border-primary-400 hover:text-primary-500 dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-500/40 dark:hover:text-primary-400"
      >
        All
      </button>
      {tags.map((tag) => (
        <button
          data-tag={tag}
          class="tag-filter cursor-pointer rounded-full border border-neutral-200 px-3 py-1 text-xs font-medium text-neutral-600 transition-colors hover:border-primary-400 hover:text-primary-500 dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-500/40 dark:hover:text-primary-400"
        >
          {tag}
        </button>
      ))}
    </div>

    <div class="mt-10 space-y-6" id="posts">
      {posts.map((post) => (
        <article class="group" data-post-tag={post.tag}>
          <a href={`/blog/${post.slug}`} class="block rounded-lg border border-neutral-100 bg-white px-6 py-5 transition-colors hover:border-primary-400/30 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:border-primary-500/40">
            <div class="flex items-center gap-2">
              <time class="text-xs text-neutral-400 dark:text-neutral-500" datetime={post.date}>
                {new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              <span class="text-neutral-200 dark:text-neutral-700">&middot;</span>
              <span class="text-xs font-medium text-primary-500 dark:text-primary-400">{post.tag}</span>
            </div>
            <h2 class="mt-1.5 text-lg font-semibold text-neutral-900 transition-colors group-hover:text-primary-500 dark:text-neutral-50 dark:group-hover:text-primary-400">{post.title}</h2>
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">{post.description}</p>
          </a>
        </article>
      ))}
    </div>

  </main>

  <Footer current="/blog" />
</Base>

<style>

  .tag-filter[data-active] {
    border-color: var(--color-primary-500);
    color: var(--color-primary-500);
    background-color: color-mix(in srgb, var(--color-primary-400) 10%, transparent);
  }

  :global(html.dark) .tag-filter[data-active] {
    border-color: var(--color-primary-400);
    color: var(--color-primary-400);
    background-color: color-mix(in srgb, var(--color-primary-400) 10%, transparent);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-filter");
  const articles = document.querySelectorAll<HTMLElement>("#posts article");

  function setFilter(tag: string) {
    buttons.forEach((btn) => {
      if (btn.dataset.tag === tag) {
        btn.setAttribute("data-active", "");
      } else {
        btn.removeAttribute("data-active");
      }
    });

    articles.forEach((article) => {
      if (tag === "all" || article.dataset.postTag === tag) {
        article.style.display = "";
      } else {
        article.style.display = "none";
      }
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      setFilter(btn.dataset.tag!);
    });
  });

  // Default: show all
  setFilter("all");
</script>
