---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";

const title = "FAQ - Pikos";
const description = "Common questions about Pikos, the free local-first app that combines notes, tasks, and calendar on your device.";

const faqs = [
  {
    q: "What is Pikos?",
    a: "A desktop app that puts notes, tasks, and a calendar in one window. Everything stored locally on your device. No account, no cloud, no subscription.",
  },
  {
    q: "Is Pikos free?",
    a: "The desktop app is a free download with no trial period and no feature limits. When iCloud sync and the iPhone app ship, those will be one-time purchases through the App Store. No subscription.",
  },
  {
    q: "What platforms does it run on?",
    a: "macOS today. Linux support is in progress. It's built with Tauri, a native app framework. Not Electron.",
  },
  {
    q: "Does it work offline?",
    a: "Completely. There are no network requests. Your notes, tasks, and calendar work identically whether you're connected or not.",
  },
  {
    q: "Where is my data stored?",
    a: "In a SQLite database on your machine. You own it. You can back it up, copy it, or export it as JSON. Pikos never sends your data anywhere.",
  },
  {
    q: "Can it replace Obsidian?",
    a: "Depends on your workflow. If you mostly write and link notes, Obsidian is purpose-built for that. If you also need task management and a calendar without plugins, Pikos does all three natively.",
  },
  {
    q: "Can it replace TickTick or Todoist?",
    a: "For personal task management with notes, yes. Pikos has priorities, statuses, folders, scheduling, and a calendar view. It doesn't have team features or cross-platform sync yet.",
  },
  {
    q: "Does it have a calendar?",
    a: "Yes. A week calendar built into the app. Drag tasks onto it to schedule them, click a slot to create a new event, and see your week alongside your notes.",
  },
  {
    q: "Does Pikos collect any data?",
    a: "No. No telemetry, no analytics in the app, no personal data. Anonymous crash reports may be sent to help fix bugs. They never contain your content.",
  },
  {
    q: "Is the source code available?",
    a: "Yes. The full source is public on GitHub. You can read it and verify that the app does what it says. It's source-available, not open-source licensed.",
  },
  {
    q: "How do I back up my data?",
    a: "Copy the SQLite file, or use the built-in JSON export. Since it's a local file, Time Machine or any backup tool catches it automatically.",
  },
  {
    q: "Does it support Markdown?",
    a: "The editor is rich text, not plain Markdown files. But you can paste Markdown and it converts automatically. Headings, lists, checkboxes, code blocks, all supported.",
  },
  {
    q: "Will there be mobile apps?",
    a: "An iPhone app is planned. Desktop comes first.",
  },
  {
    q: "Will there be sync?",
    a: "iCloud sync is planned for the Mac App Store version (one-time purchase). The free direct download stays local-only. The iPhone app will be a separate one-time purchase. Sync uses Apple's infrastructure. Your data won't touch Pikos servers.",
  },
  {
    q: "What makes it different?",
    a: "Most apps specialize. Obsidian does notes. TickTick does tasks. Fantastical does calendar. Pikos combines all three in one native app. Local-first, free, no account, data in an open format. One app instead of three.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": a,
    },
  })),
};
---

<Base title={title} description={description} jsonLd={faqJsonLd}>

  <main class="mx-auto max-w-2xl px-8 py-20">

    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-400 transition-colors hover:text-orange-500 dark:text-gray-500 dark:hover:text-orange-400">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      Home
    </a>

    <h1 class="mt-8 text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-50">Questions</h1>
    <p class="mt-3 text-base text-gray-500 dark:text-gray-400">
      Straight answers, no fluff.
    </p>

    <div class="mt-12 divide-y divide-gray-200 dark:divide-gray-800">
      {faqs.map(({ q, a }) => (
        <div class="py-6">
          <h2 class="font-semibold text-gray-900 dark:text-gray-50">{q}</h2>
          <p class="mt-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400">{a}</p>
        </div>
      ))}
    </div>

  </main>

  <Footer current="/faq" />
</Base>

<style>
  :global(body) {
    background-color: #fafaf9;
  }

  :global(html.dark body) {
    background-color: #030712;
  }
</style>
