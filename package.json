{
  "name": "pkos",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "dev:desktop": "pnpm --filter @pikos/desktop tauri dev",
    "dev:marketing": "pnpm --filter @pkos/marketing dev",
    "build": "turbo build",
    "test": "turbo test",
    "prepare": "husky",
    "verify": "bash scripts/verify.sh",
    "seed": "tsx scripts/seed/index.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.0.3",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.21",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write --log-level warn",
      "eslint --fix"
    ],
    "*.{js,json,css,md}": "prettier --write --log-level warn"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
