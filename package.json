{
  "name": "pkos",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "depcruise": "depcruise apps/desktop/src packages/core/src --config .dependency-cruiser.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "turbo": "^2",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write --log-level warn",
      "eslint --fix"
    ],
    "*.{js,json,css,md}": "prettier --write --log-level warn"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
