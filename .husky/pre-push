pnpm check
pnpm exec turbo test
# Tier 1 E2E — requires Playwright browsers (npx playwright install webkit)
# Skip when SKIP_E2E is set or browsers aren't installed
if [ -z "$SKIP_E2E" ] && npx playwright test --list --project tier1 >/dev/null 2>&1; then
  pnpm --filter @pikos/desktop test:e2e -- --project tier1 -x
fi
